<script>
(function () {
    var endpoint = '<?= $block->escapeUrl($block->getUrl('ticpan/error/report')) ?>';
    window.addEventListener('error', function (e) {
        try {
            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: (e.message || '').substring(0, 500),
                    source:  (e.filename || '').substring(0, 500),
                    url:     window.location.href.substring(0, 500)
                }),
                keepalive: true
            });
        } catch (_) {}
    });
    window.addEventListener('unhandledrejection', function (e) {
        try {
            var msg = (e.reason && e.reason.message) ? e.reason.message : String(e.reason || 'Unhandled rejection');
            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: msg.substring(0, 500),
                    source:  '',
                    url:     window.location.href.substring(0, 500)
                }),
                keepalive: true
            });
        } catch (_) {}
    });
}());
</script>
